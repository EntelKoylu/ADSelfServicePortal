@{
    ViewData["Title"] = "Şifre Sıfırlama";
    // Kullanıcı adı dolu mu geldi kontrol ediyoruz
    bool isLocked = ViewBag.PreFilledUsername != null;
}

<div class="w-full max-w-lg bg-white/90 backdrop-blur-md rounded-2xl shadow-soft border border-gray-100 p-8 mt-4">

    <div class="flex items-center justify-between mb-8">
        <div>
            <h3 class="text-xl font-bold text-gray-800">Şifre Yenileme</h3>
            <p class="text-gray-500 text-sm mt-1">Güvenliğiniz için güçlü bir şifre seçin.</p>
        </div>
        <div class="h-12 w-12 bg-blue-100 rounded-xl flex items-center justify-center text-primary">
            <i class="ri-shield-keyhole-line text-2xl"></i>
        </div>
    </div>

    @if (ViewBag.Message != null)
    {
        <div class="mb-6 p-4 rounded-lg flex items-center gap-3 @(ViewBag.Renk == "success" ? "bg-green-50 text-green-700 border border-green-100" : "bg-red-50 text-red-700 border border-red-100")">
            <i class="@(ViewBag.Renk == "success" ? "ri-checkbox-circle-line" : "ri-error-warning-line") text-xl"></i>
            <span class="text-sm font-medium">@ViewBag.Message</span>
        </div>
    }

    <form action="/Home/ChangePassword" method="post" class="space-y-5">
        @Html.AntiForgeryToken()

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2 ml-1">
                Kullanıcı Adı
                @if (isLocked)
                {
                    <span class="text-xs text-gray-400 font-normal ml-2">(Değiştirilemez)</span>
                }
            </label>

            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <i class="@(isLocked ? "ri-lock-2-fill text-gray-400" : "ri-user-line text-gray-400")"></i>
                </div>

                <input type="text" name="username"
                       value="@ViewBag.PreFilledUsername"
                       class="form-input w-full pl-11 pr-4 py-3 border border-gray-200 rounded-button outline-none transition-all
                              @(isLocked ? "bg-gray-100 text-gray-500 cursor-not-allowed border-gray-100" : "bg-gray-50 text-gray-800 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10")"
                       placeholder="ad.soyad"
                       required
                       @(isLocked ? "readonly" : "")>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2 ml-1">Eski Şifre</label>
                <input type="password" name="oldPassword" class="form-input w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-button focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none" required autofocus>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2 ml-1">Yeni Şifre</label>
                <input type="password" name="newPassword" class="form-input w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-button focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none" required>
            </div>
        </div>

        <div class="bg-blue-50 p-4 rounded-lg border border-blue-100">
            <h5 class="text-blue-800 text-xs font-bold uppercase tracking-wider mb-2">Şifre Politikası</h5>
            <ul class="text-blue-700 text-xs space-y-1 list-disc list-inside">
                <li>En az 8 karakter uzunluğunda olmalı</li>
                <li>Büyük harf, küçük harf ve rakam içermeli</li>
            </ul>
        </div>

        <div class="flex gap-3 pt-4">
            <a href="/Home/Index" class="w-1/3 flex justify-center items-center px-4 py-3 border border-gray-200 text-gray-600 font-semibold rounded-button hover:bg-gray-50 transition-colors">
                İptal
            </a>

            <button type="submit" class="w-2/3 bg-primary hover:bg-blue-600 text-white font-semibold py-3 rounded-button shadow-lg shadow-blue-500/30 transition-all transform active:scale-95 flex justify-center items-center gap-2">
                <i class="ri-refresh-line"></i>
                Şifreyi Güncelle
            </button>
        </div>

    </form>
</div>