@{
    ViewData["Title"] = "Yeni Şifre Belirle";
}

<div class="w-full max-w-lg bg-white/90 backdrop-blur-md rounded-2xl shadow-soft border border-gray-100 p-8 mt-4">

    <div class="flex items-center justify-between mb-6">
        <div>
            <h3 class="text-xl font-bold text-gray-800">Yeni Şifre Belirle</h3>
            <p class="text-gray-500 text-sm mt-1">Lütfen hesabınız için yeni bir şifre oluşturun.</p>
        </div>
        <div class="h-12 w-12 bg-purple-100 rounded-xl flex items-center justify-center text-purple-600">
            <i class="ri-key-2-fill text-2xl"></i>
        </div>
    </div>

    @if (ViewBag.Message != null)
    {
        <div class="mb-6 p-4 rounded-lg flex items-center gap-3 @(ViewBag.Renk == "success" ? "bg-green-50 text-green-700 border border-green-100" : "bg-red-50 text-red-700 border border-red-100")">
            <i class="@(ViewBag.Renk == "success" ? "ri-checkbox-circle-line" : "ri-error-warning-line") text-xl"></i>
            <span class="text-sm font-medium">@ViewBag.Message</span>
        </div>
    }

    <form action="/Home/SetNewPassword" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" name="token" value="@ViewBag.Token" />

        <div>
            <label class="block text-sm font-semibold text-gray-500 mb-2 ml-1">İşlem Yapılan Hesap</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <i class="ri-user-fill text-gray-400"></i>
                </div>
                <input type="text" value="@ViewBag.Username"
                       class="form-input w-full pl-11 pr-4 py-3 bg-gray-100 border border-gray-200 rounded-button text-gray-600 cursor-not-allowed outline-none"
                       readonly>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2 ml-1">Yeni Şifre</label>
            <input type="password" name="newPassword" class="form-input w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-button focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none" placeholder="********" required autofocus>
            <p class="text-xs text-gray-400 mt-2 ml-1">
                * En az 8 karakter, büyük harf ve rakam.
            </p>
        </div>

        <div class="pt-4">
            <button type="submit" class="w-full bg-primary hover:bg-blue-600 text-white font-semibold py-3.5 rounded-button shadow-lg shadow-blue-500/30 transition-all transform active:scale-95 flex justify-center items-center gap-2">
                <i class="ri-check-double-line"></i>
                Şifreyi Sıfırla
            </button>

            <div class="text-center mt-4">
                <a href="/Home/Index" class="text-sm text-gray-500 hover:text-gray-700">İşlemi İptal Et</a>
            </div>
        </div>
    </form>
</div>