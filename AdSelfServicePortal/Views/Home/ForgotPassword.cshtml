@{
    ViewData["Title"] = "Kimlik Doğrulama";
}

<div class="w-full max-w-lg bg-white/90 backdrop-blur-md rounded-2xl shadow-soft border border-gray-100 p-8 mt-4">

    <div class="flex items-center justify-between mb-8">
        <div>
            <h3 class="text-xl font-bold text-gray-800">Hesabınızı Bulun</h3>
            <p class="text-gray-500 text-sm mt-1">İşlem yapmak istediğiniz hesabı girin.</p>
        </div>
        <div class="h-12 w-12 bg-blue-100 rounded-xl flex items-center justify-center text-primary">
            <i class="ri-user-search-line text-2xl"></i>
        </div>
    </div>

    @if (ViewBag.Message != null)
    {
        <div class="mb-6 p-4 rounded-lg bg-yellow-50 text-yellow-700 border border-yellow-100 flex items-center gap-3">
            <i class="ri-error-warning-line text-xl"></i>
            <span class="text-sm font-medium">@ViewBag.Message</span>
        </div>
    }

    <form action="/Home/ForgotPassword" method="post" class="space-y-6">
        @Html.AntiForgeryToken()

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2 ml-1">Kullanıcı Adı</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <i class="ri-user-line text-gray-400"></i>
                </div>
                <input type="text" name="username"
                       class="form-input w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-button text-gray-800 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none"
                       placeholder="ad.soyad" required autofocus>
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <a href="/Home/Index" class="w-1/3 flex justify-center items-center px-4 py-3 border border-gray-200 text-gray-600 font-semibold rounded-button hover:bg-gray-50 transition-colors group">
                <i class="ri-arrow-left-s-line mr-1 transition-transform group-hover:-translate-x-1"></i>
                Geri
            </a>

            <button type="submit" class="w-2/3 bg-primary hover:bg-blue-600 text-white font-semibold py-3 rounded-button shadow-lg shadow-blue-500/30 transition-all transform active:scale-95 flex justify-center items-center gap-2">
                Devam Et
                <i class="ri-arrow-right-line"></i>
            </button>
        </div>
    </form>
</div>