@using Microsoft.AspNetCore.Http
@using AdSelfServicePortal.Constants
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - ParamTech Portal</title>

    <script src="https://cdn.tailwindcss.com/3.4.16"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { primary: '#3b82f6', secondary: '#10b981', dark: '#1f2937' },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.6.0/remixicon.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col bg-gray-50/30">

    <nav class="w-full border-b border-gray-100 bg-white/80 backdrop-blur-md sticky top-0 z-50">
        <div class="container mx-auto px-4 py-3">
            <div class="flex justify-between items-center">

                <div class="flex items-center gap-4">
                    <a href="/Home/Index" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
                        <img src="https://sanalpospro.com/wp-content/uploads/2020/12/parampos-logo-01-uai-1032x213.png" alt="Param Logo" class="h-8 w-auto">
                        <div class="h-6 w-px bg-gray-200"></div>
                        <span class="text-gray-700 font-semibold text-sm tracking-tight hidden md:block">AD Self Servis</span>
                    </a>
                </div>

                <div class="flex items-center gap-4">
                    @{
                        var normalUser = HttpContextAccessor.HttpContext?.Session.GetString(SessionKeys.User);
                        var adminUser = HttpContextAccessor.HttpContext?.Session.GetString(SessionKeys.AdminUser);
                    }

                    @if (adminUser != null)
                    {
                        <div class="flex items-center gap-3 pl-4 border-l border-gray-100">
                            <div class="flex items-center gap-2">
                                <div class="h-8 w-8 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                                    <i class="ri-shield-user-fill"></i>
                                </div>
                                <div class="hidden md:block text-right">
                                    <p class="text-xs text-gray-400 font-medium">Yönetici</p>
                                    <p class="text-sm font-bold text-gray-800 leading-none">@adminUser</p>
                                </div>
                            </div>
                            <a href="/Admin/Logout" class="group flex items-center justify-center h-9 w-9 rounded-lg border border-red-100 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white transition-all duration-300" title="Çıkış">
                                <i class="ri-logout-box-line text-lg"></i>
                            </a>
                        </div>
                    }
                    else if (normalUser != null)
                    {
                        <div class="flex items-center gap-3 pl-4 border-l border-gray-100">
                            <div class="flex items-center gap-2">
                                <div class="h-8 w-8 rounded-full bg-blue-50 flex items-center justify-center text-primary shadow-sm border border-blue-100">
                                    <i class="ri-user-smile-line"></i>
                                </div>
                                <div class="hidden md:block text-right">
                                    <p class="text-xs text-gray-400 font-medium">Oturum Açan</p>
                                    <p class="text-sm font-bold text-gray-800 leading-none">@normalUser</p>
                                </div>
                            </div>
                            <a href="/Home/Logout" class="group flex items-center justify-center h-9 w-9 rounded-lg border border-red-100 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white transition-all duration-300" title="Çıkış">
                                <i class="ri-logout-box-r-line text-lg"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow container mx-auto px-4 py-8">

        @if (adminUser != null)
        {
            <div class="flex flex-col md:flex-row gap-6 items-start">

                <aside class="w-full md:w-64 bg-white rounded-2xl shadow-soft border border-gray-100 overflow-hidden flex-shrink-0 sticky top-24">
                    <div class="p-4 bg-gray-50 border-b border-gray-100">
                        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Yönetim Menüsü</h4>
                    </div>
                    <nav class="p-2 space-y-1">

                        <a href="/Admin/Index" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 rounded-xl hover:bg-indigo-50 hover:text-indigo-600 transition-colors group @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "bg-indigo-50 text-indigo-600" : "")">
                            <span class="h-8 w-8 rounded-lg bg-gray-100 flex items-center justify-center text-gray-500 group-hover:bg-white group-hover:text-indigo-600 transition-colors">
                                <i class="ri-dashboard-line text-lg"></i>
                            </span>
                            Ana Sayfa
                        </a>

                        <a href="/Admin/UserSearch" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 rounded-xl hover:bg-indigo-50 hover:text-indigo-600 transition-colors group @(ViewContext.RouteData.Values["Action"].ToString() == "UserSearch" ? "bg-indigo-50 text-indigo-600" : "")">
                            <span class="h-8 w-8 rounded-lg bg-gray-100 flex items-center justify-center text-gray-500 group-hover:bg-white group-hover:text-indigo-600 transition-colors">
                                <i class="ri-search-eye-line text-lg"></i>
                            </span>
                            Kullanıcı Arama
                        </a>

                        <a href="/Admin/ActivityLogs" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 rounded-xl hover:bg-indigo-50 hover:text-indigo-600 transition-colors group @(ViewContext.RouteData.Values["Action"].ToString() == "ActivityLogs" ? "bg-indigo-50 text-indigo-600" : "")">
                            <span class="h-8 w-8 rounded-lg bg-gray-100 flex items-center justify-center text-gray-500 group-hover:bg-white group-hover:text-indigo-600 transition-colors">
                                <i class="ri-history-line text-lg"></i>
                            </span>
                            Aktivite Geçmişi
                        </a>

                    </nav>
                </aside>

                <div class="flex-grow w-full">
                    @RenderBody()
                </div>
            </div>
        }
        else
        {
            <div class="flex justify-center items-start">
                @RenderBody()
            </div>
        }

    </main>

    <footer class="py-6 mt-auto border-t border-gray-100 bg-white">
        <div class="text-center text-sm text-gray-500">
            <span>© 2025 ParamTech</span>
            <span class="mx-2 text-gray-300">|</span>
            <a href="/Home/Privacy" class="font-medium text-primary hover:text-blue-700 transition-colors hover:underline">
                Gizlilik Sözleşmesi
            </a>
        </div>
    </footer>

    @if (adminUser != null)
    {
        <script>
            setTimeout(function() {
                window.location.href = '/Admin/Logout';
            }, 300000); // 300.000 ms = 5 Dakika
        </script>
    }

</body>
</html>