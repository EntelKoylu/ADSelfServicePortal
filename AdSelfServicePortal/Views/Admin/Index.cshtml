@model AdSelfServicePortal.Models.DashboardViewModel

@{
    ViewData["Title"] = "Yönetim Paneli";
}

<div class="w-full max-w-7xl mx-auto space-y-8 mt-6">

    <div>
        <h2 class="text-2xl font-bold text-gray-800">Sistem Özeti</h2>
        <p class="text-gray-500 text-sm">Anlık sistem durumu ve istatistikler.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">

        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between h-24">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Toplam Personel</p>
            <div class="flex justify-between items-end">
                <p id="totalCount" class="text-2xl font-bold text-gray-800">@Model.TotalUsersCount</p>
                <i class="ri-group-line text-gray-300 text-xl"></i>
            </div>
        </div>

        <div class="bg-red-50 rounded-xl p-4 shadow-sm border border-red-100 flex flex-col justify-between h-24">
            <p class="text-[10px] font-bold text-red-400 uppercase tracking-wider">Anlık Kilitli</p>
            <div class="flex justify-between items-end">
                <p id="lockedCount" class="text-2xl font-bold text-red-600">@Model.LockedUsersCount</p>
                <div class="relative">
                    <i class="ri-lock-fill text-red-300 text-xl"></i>
                    @if (Model.LockedUsersCount > 0)
                    {
                        <span class="absolute top-0 right-0 flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                        </span>
                    }
                </div>
            </div>
        </div>

        <div class="bg-gray-50 rounded-xl p-4 shadow-sm border border-gray-200 flex flex-col justify-between h-24">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Pasif Hesaplar</p>
            <div class="flex justify-between items-end">
                <p id="disabledCount" class="text-2xl font-bold text-gray-600">@Model.DisabledUsersCount</p>
                <i class="ri-user-unfollow-line text-gray-300 text-xl"></i>
            </div>
        </div>

        <div class="bg-indigo-50 rounded-xl p-4 shadow-sm border border-indigo-100 flex flex-col justify-between h-24">
            <p class="text-[10px] font-bold text-indigo-400 uppercase tracking-wider">Admin Reset</p>
            <div class="flex justify-between items-end">
                <p id="dbResetCount" class="text-2xl font-bold text-indigo-600">@Model.TotalResets</p>
                <i class="ri-admin-line text-indigo-300 text-xl"></i>
            </div>
        </div>

        <div class="bg-emerald-50 rounded-xl p-4 shadow-sm border border-emerald-100 flex flex-col justify-between h-24">
            <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-wider">Kilit Açma</p>
            <div class="flex justify-between items-end">
                <p id="dbUnlockCount" class="text-2xl font-bold text-emerald-600">@Model.TotalUnlocks</p>
                <i class="ri-lock-unlock-line text-emerald-300 text-xl"></i>
            </div>
        </div>

        <div class="bg-blue-50 rounded-xl p-4 shadow-sm border border-blue-100 flex flex-col justify-between h-24">
            <p class="text-[10px] font-bold text-blue-400 uppercase tracking-wider">Self Servis</p>
            <div class="flex justify-between items-end">
                <p id="dbChangeCount" class="text-2xl font-bold text-blue-600">@Model.TotalChanges</p>
                <i class="ri-user-settings-line text-blue-300 text-xl"></i>
            </div>
        </div>

    </div>

    <div id="lockedUsersPanel" class="@(Model.LockedUsers.Count > 0 ? "" : "hidden") bg-white rounded-2xl shadow-soft border border-red-100 overflow-hidden transition-all duration-500">
        <div class="bg-red-50 px-6 py-4 border-b border-red-100 flex justify-between items-center">
            <h3 class="font-bold text-red-800 flex items-center gap-2">
                <i class="ri-alarm-warning-fill animate-pulse"></i> Acil Müdahale: Kilitli Hesaplar
            </h3>
            <span id="lockedListBadge" class="text-xs bg-white text-red-600 px-2 py-1 rounded font-bold border border-red-100">@Model.LockedUsers.Count Kişi</span>
        </div>
        <table class="w-full text-left">
            <tbody id="lockedUsersTableBody" class="divide-y divide-red-50">
                @foreach (var user in Model.LockedUsers)
                {
                    <tr class="hover:bg-red-50/50 transition-colors">
                        <td class="px-6 py-4 font-medium text-gray-800">@user.DisplayName</td>
                        <td class="px-6 py-4 text-gray-500 text-sm">@user.Username</td>
                        <td class="px-6 py-4 text-right">
                            <form action="/Admin/UnlockUser" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="username" value="@user.Username" />
                                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white text-xs font-bold px-4 py-2 rounded-lg shadow-sm transition-colors flex items-center gap-1 ml-auto">
                                    <i class="ri-lock-unlock-line"></i> HIZLI AÇ
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <a href="/Admin/UserSearch" class="group bg-white/80 backdrop-blur-sm border border-gray-200 hover:border-indigo-300 p-6 rounded-2xl shadow-sm hover:shadow-md transition-all flex items-center gap-4">
            <div class="h-14 w-14 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <i class="ri-user-search-line text-3xl"></i>
            </div>
            <div>
                <h4 class="text-lg font-bold text-gray-800 group-hover:text-indigo-700 transition-colors">Kullanıcı Arama</h4>
                <p class="text-sm text-gray-500">Kullanıcı bul, şifre sıfırla veya detayları incele.</p>
            </div>
            <div class="ml-auto text-gray-300 group-hover:text-indigo-400">
                <i class="ri-arrow-right-line text-2xl"></i>
            </div>
        </a>

        <a href="/Admin/ActivityLogs" class="group bg-white/80 backdrop-blur-sm border border-gray-200 hover:border-indigo-300 p-6 rounded-2xl shadow-sm hover:shadow-md transition-all flex items-center gap-4">
            <div class="h-14 w-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <i class="ri-file-list-3-line text-3xl"></i>
            </div>
            <div>
                <h4 class="text-lg font-bold text-gray-800 group-hover:text-blue-700 transition-colors">Aktivite Geçmişi</h4>
                <p class="text-sm text-gray-500">Sistem loglarını ve geçmiş işlemleri görüntüle.</p>
            </div>
            <div class="ml-auto text-gray-300 group-hover:text-blue-400">
                <i class="ri-arrow-right-line text-2xl"></i>
            </div>
        </a>

    </div>

</div>

<script>
    function escapeHtml(text) {
        if (!text) return '';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    function fetchLiveStats() {
        fetch('/Admin/GetLiveStats')
            .then(response => {
                if(response.status === 401 || response.status === 403) {
                    window.location.href = '/Admin/Login';
                    return;
                }
                return response.json();
            })
            .then(data => {
                if(!data) return;

                updateText("totalCount", data.totalUsersCount);
                updateText("lockedCount", data.lockedUsersCount);
                updateText("disabledCount", data.disabledUsersCount);

                updateText("dbResetCount", data.totalResets);
                updateText("dbUnlockCount", data.totalUnlocks);
                updateText("dbChangeCount", data.totalChanges);

                var lockedPanel = document.getElementById("lockedUsersPanel");
                var tbody = document.getElementById("lockedUsersTableBody");
                var badge = document.getElementById("lockedListBadge");

                if (data.lockedUsers && data.lockedUsers.length > 0) {
                    lockedPanel.classList.remove("hidden");
                    badge.innerText = data.lockedUsers.length + " Kişi";

                    tbody.innerHTML = '';
                    data.lockedUsers.forEach(user => {
                        var tr = document.createElement('tr');
                        tr.className = 'hover:bg-red-50/50 transition-colors';

                        var td1 = document.createElement('td');
                        td1.className = 'px-6 py-4 font-medium text-gray-800';
                        td1.textContent = user.displayName || user.username;

                        var td2 = document.createElement('td');
                        td2.className = 'px-6 py-4 text-gray-500 text-sm';
                        td2.textContent = user.username;

                        var td3 = document.createElement('td');
                        td3.className = 'px-6 py-4 text-right';

                        var form = document.createElement('form');
                        form.action = '/Admin/UnlockUser';
                        form.method = 'post';
                        form.className = 'inline';

                        var hiddenInput = document.createElement('input');
                        hiddenInput.type = 'hidden';
                        hiddenInput.name = 'username';
                        hiddenInput.value = user.username;

                        var btn = document.createElement('button');
                        btn.type = 'submit';
                        btn.className = 'bg-red-600 hover:bg-red-700 text-white text-xs font-bold px-4 py-2 rounded-lg shadow-sm transition-colors flex items-center gap-1 ml-auto';
                        btn.innerHTML = '<i class="ri-lock-unlock-line"></i> HIZLI A\u00C7';

                        form.appendChild(hiddenInput);
                        form.appendChild(btn);
                        td3.appendChild(form);

                        tr.appendChild(td1);
                        tr.appendChild(td2);
                        tr.appendChild(td3);
                        tbody.appendChild(tr);
                    });

                } else {
                    lockedPanel.classList.add("hidden");
                }
            })
            .catch(err => console.log("Veri güncellenirken hata oluştu."));
    }

    function updateText(id, value) {
        var el = document.getElementById(id);
        if(el) el.innerText = value;
    }

    setInterval(fetchLiveStats, 5000);
</script>