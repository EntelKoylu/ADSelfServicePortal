@model AdSelfServicePortal.Models.AdUserModel

@{
    ViewData["Title"] = "Kullanıcı Şifresi Sıfırla";
}

<div class="w-full max-w-lg bg-white/90 backdrop-blur-md rounded-2xl shadow-soft border border-gray-100 p-8 mt-4 mx-auto">

    <div class="flex items-center justify-between mb-8">
        <div>
            <h3 class="text-xl font-bold text-gray-800">Admin Şifre Sıfırlama</h3>
            <p class="text-gray-500 text-sm mt-1">
                <span class="font-bold text-primary">@Model.Username</span> kullanıcısı için yeni şifre belirliyorsunuz.
            </p>
        </div>
        <div class="h-12 w-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
            <i class="ri-admin-fill text-2xl"></i>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="mb-6 p-4 rounded-lg bg-red-50 text-red-700 border border-red-100 flex items-center gap-3">
            <i class="ri-error-warning-line text-xl"></i>
            <span class="font-medium">@TempData["Error"]</span>
        </div>
    }

    <form action="/Admin/ResetUserPassword" method="post" class="space-y-5">
        @Html.AntiForgeryToken()

        <input type="hidden" name="username" value="@Model.Username" />

        <div>
            <label for="reset-newPassword" class="block text-sm font-semibold text-gray-700 mb-2 ml-1">Yeni Şifre</label>
            <input type="password" id="reset-newPassword" name="newPassword" class="form-input w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-button focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none" placeholder="Yeni şifreyi buraya yazın..." required autofocus>
        </div>

        <div class="flex gap-3 pt-4">
            <a href="/Admin/UserSearch?search=@Model.Username" class="w-1/3 flex justify-center items-center px-4 py-3 border border-gray-200 text-gray-600 font-semibold rounded-button hover:bg-gray-50 transition-colors">
                İptal
            </a>
            <button type="submit" class="w-2/3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-button shadow-lg shadow-indigo-500/30 transition-all transform active:scale-95 flex justify-center items-center gap-2">
                <i class="ri-save-line"></i>
                Şifreyi Kaydet
            </button>
        </div>
    </form>
</div>
