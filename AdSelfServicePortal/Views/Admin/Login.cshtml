@{
    ViewData["Title"] = "Yönetici Girişi";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="w-full max-w-md bg-white/90 backdrop-blur-md rounded-2xl shadow-soft border border-gray-100 p-8 mt-4 mx-auto">

        <div class="text-center mb-8">
            <div class="h-16 w-16 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 mx-auto mb-4 shadow-sm">
                <i class="ri-shield-keyhole-fill text-3xl"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-800">Yönetici Paneli</h3>
            <p class="text-gray-500 text-sm mt-1">Yetkili personel giriş ekranı.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="mb-6 p-4 rounded-lg bg-red-50 text-red-700 border border-red-100 flex items-center gap-3">
                <i class="ri-error-warning-line text-xl"></i>
                <span class="text-sm font-medium">@ViewBag.Error</span>
            </div>
        }

        <form action="/Admin/Login" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2 ml-1">Yönetici Kullanıcı Adı</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="ri-admin-line text-gray-400"></i>
                    </div>
                    <input type="text" name="username" class="form-input w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-button text-gray-800 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none" placeholder="admin.user" required>
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2 ml-1">Şifre</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="ri-lock-password-line text-gray-400"></i>
                    </div>
                    <input type="password" name="password" class="form-input w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-button text-gray-800 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3.5 rounded-button shadow-lg shadow-indigo-500/30 transition-all transform active:scale-95 flex justify-center items-center gap-2">
                <i class="ri-login-circle-line"></i>
                Panele Giriş Yap
            </button>

            <div class="text-center mt-4">
                <a href="/Home/Index" class="text-sm text-gray-500 hover:text-primary flex items-center justify-center gap-1">
                    <i class="ri-arrow-left-line"></i> Kullanıcı Portalına Dön
                </a>
            </div>
        </form>
    </div>
</div>